# =============================================================================
# Tenet EDI Transform Service — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Server ---
HOST=0.0.0.0
PORT=3000
AS2_PORT=4080
NODE_ENV=production

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tenet_edi
DATABASE_URL=postgres://postgres:changeme@postgres:5432/tenet_edi

# --- SFTP Connector ---
SFTP_HOST=sftp
SFTP_PORT=22
SFTP_USER=ediuser
SFTP_PASSWORD=sftppass
# SFTP_PRIVATE_KEY=   # PEM key contents (alternative to password)
SFTP_INBOUND_DIR=/home/ediuser/inbound
SFTP_OUTBOUND_DIR=/home/ediuser/outbound
SFTP_ARCHIVE_DIR=/home/ediuser/archive
SFTP_POLL_INTERVAL_MS=30000

# --- AS2 ---
AS2_SENDER_ID=TENET-EDI
AS2_CERT_PATH=/certs/as2.crt
AS2_KEY_PATH=/certs/as2.key

# --- Routing Rules (JSON array) ---
# Each rule: { "transactionSet": "204", "endpoint": "https://...", "apiKey": "...", "retries": 3 }
ROUTING_RULES=[]

# --- Map Persistence ---
MAPS_DB_PATH=./maps/db

# --- Django Ops Platform ---
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,ops

# --- Engine API (used by Django) ---
ENGINE_API_URL=http://engine:3000
ENGINE_API_KEY=

# --- Anthropic (for AI DSL generation) ---
ANTHROPIC_API_KEY=sk-ant-...
