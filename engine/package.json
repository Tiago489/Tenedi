{
  "name": "edi-transform-engine",
  "version": "1.0.0",
  "description": "EDI transformation engine — parse, map, route",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "worker:inbound": "ts-node-dev --respawn --transpile-only src/queue/workers/inbound.ts",
    "worker:outbound": "ts-node-dev --respawn --transpile-only src/queue/workers/outbound.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@mistweaverco/libas2": "^0.3.0",
    "axios": "^1.6.8",
    "bullmq": "^5.4.2",
    "chevrotain": "^11.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "jsonata": "^2.0.5",
    "lodash": "^4.17.21",
    "node-schedule": "^2.1.1",
    "pino": "^8.19.0",
    "ssh2-sftp-client": "^10.0.3",
    "x12-parser": "^1.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.12.7",
    "@types/node-schedule": "^2.1.6",
    "@types/ssh2-sftp-client": "^9.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
